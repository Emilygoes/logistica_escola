from fastapi import FastAPI

app = FastAPI()

@app.get("/")
def inicio():
    return {"mensagem": "API da Escola funcionando!"}

ALUNOS
@app.get("/alunos")
def listar_alunos():
    return {"mensagem": "Lista de alunos"}

@app.get("/alunos/{id}")
def buscar_aluno(id: int):
    return {"mensagem": f"Aluno {id}"}

@app.post("/alunos")
def cadastrar_aluno(aluno: dict):
    return aluno

@app.put("/alunos/{id}")
def atualizar_aluno(id: int, aluno: dict):
    return {"id": id, "dados": aluno}

@app.delete("/alunos/{id}")
def excluir_aluno(id: int):
    return {"mensagem": f"Aluno {id} excluído"}

